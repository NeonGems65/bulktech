# Local development (option A): use individual PG_* variables
PGHOST=localhost
PGPORT=5433
PGDATABASE=bulktech
PGUSER=postgres
PGPASSWORD=your_password_here

# Production/deploy (option B): use a single connection string (Render/Fly/Railway/etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Phase 1 migration preflight
# Render source database (fallbacks to DATABASE_URL if omitted)
# RENDER_DATABASE_URL=postgresql://user:password@render-host:5432/source_db?sslmode=require

# Neon target metadata and URLs
# NEON_PROJECT_ID=
# NEON_BRANCH_ID=
# NEON_DATABASE=neondb
# NEON_ROLE=neondb_owner
# NEON_POOLED_DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# NEON_DIRECT_DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Note network configuration used for Neon access (IP allow-list/private networking)
# NEON_NETWORK_NOTES=

# Phase 2 maintenance lock (set true during final source export)
# MAINTENANCE_WRITE_LOCK=false

# Phase 3 Neon prep and cutover guidance
# Keep DATABASE_URL pointed to your current provider until cutover.
# During cutover, set DATABASE_URL to NEON_POOLED_DATABASE_URL for app runtime.
# Reserve NEON_DIRECT_DATABASE_URL for admin operations (restore/migrations/preflight checks).

# Phase 4 optional overrides
# PHASE4_DUMP_PATH=server/preflight-artifacts/phase2-render-full-<timestamp>.dump
# PHASE4_BASELINE_PATH=server/preflight-artifacts/phase2-render-baseline-<timestamp>.json
# PHASE4_API_BASE_URL=http://localhost:5000
# PHASE4_SKIP_API_SMOKE=false

# Phase 5 optional controls
# PHASE5_API_BASE_URL=http://localhost:5000
# PHASE5_APPLY_LOCAL_DATABASE_URL_SWITCH=false
# PHASE5_SKIP_HEALTH_CHECK=false

NODE_ENV=development
PORT=5000
